FROM golang:1.22-bookworm AS builder

RUN apt-get update && apt-get install -y --no-install-recommends \
    clang llvm libbpf-dev linux-headers-generic && \
    rm -rf /var/lib/apt/lists/*

WORKDIR /src
COPY go.mod go.sum* ./
RUN go mod tidy && go mod download
COPY . .
RUN make bpf
RUN CGO_ENABLED=0 go build -ldflags "-s -w" -o /flowpulse-agent ./cmd/agent

FROM gcr.io/distroless/static-debian12:nonroot
COPY --from=builder /flowpulse-agent /flowpulse-agent
COPY --from=builder /src/bpf/*.o /bpf/
COPY configs/agent.yaml /etc/flowpulse/agent.yaml

HEALTHCHECK --interval=10s --timeout=3s CMD ["/flowpulse-agent", "healthcheck"]

USER nonroot:nonroot
ENTRYPOINT ["/flowpulse-agent"]
